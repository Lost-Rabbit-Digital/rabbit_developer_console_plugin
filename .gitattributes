# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Exclude demo project and dev files from `git archive` (e.g. GitHub ZIP downloads).
# Only the addons/ plugin folder will be included in the downloaded archive.
.gitattributes export-ignore
.gitignore export-ignore
.editorconfig export-ignore
LICENSE export-ignore
README.md export-ignore
*.png export-ignore
*.svg export-ignore
*.import export-ignore
main.gd export-ignore
main.gd.uid export-ignore
main.tscn export-ignore
project.godot export-ignore
